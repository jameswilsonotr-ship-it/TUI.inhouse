{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tui.inhouse/schemas/window/1.0.0",
  "title": "TUI.inhouse Output Windows",
  "type": "object",
  "required": ["schema_version", "windows"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "windows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "panel"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "panel": { "type": "string" },
          "title": { "type": "string" },
          "streams": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["stdout", "stderr", "both", "events"]
            }
          },
          "render_as": {
            "type": "string",
            "enum": ["log", "markdown", "html", "ansi", "json"]
          },
          "buffer_lines": { "type": "number", "minimum": 1 },
          "markdown_safe": { "type": "boolean" },
          "html_safe": { "type": "boolean" },
          "show_exit_banner": { "type": "boolean" }
        }
      }
    }
  }
}
