{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tui.inhouse/schemas/layout/1.0.0",
  "title": "TUI.inhouse Screen Layout",
  "type": "object",
  "required": ["schema_version", "id", "regions", "panels"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string" },
    "orientation": { "type": "string", "enum": ["vertical", "horizontal"] },
    "regions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "role", "panels"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "role": {
            "type": "string",
            "enum": [
              "header",
              "navigation",
              "main",
              "output",
              "status",
              "footer",
              "modal",
              "extension"
            ]
          },
          "size": { "type": "string" },
          "panels": {
            "type": "array",
            "items": { "type": "string" }
          },
          "visible": { "type": "boolean" }
        }
      }
    },
    "panels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "role"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "role": {
            "type": "string",
            "enum": ["chrome", "menu", "content", "output", "status", "dialog"]
          },
          "content_types": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["markdown", "html", "plain", "log", "ansi", "widget", "json"]
            }
          },
          "default_content_type": { "type": "string" },
          "scroll": { "type": "boolean" },
          "focusable": { "type": "boolean" },
          "min_size": { "type": "number" },
          "border": {
            "type": "string",
            "enum": ["none", "single", "heavy", "double"]
          },
          "gutter_reactive": { "type": "boolean" }
        }
      }
    },
    "bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slot", "panel"],
        "additionalProperties": true,
        "properties": {
          "slot": { "type": "string" },
          "panel": { "type": "string" },
          "priority": { "type": "number" }
        }
      }
    },
    "css_hints": { "type": "object", "additionalProperties": true },
    "extensions": { "type": "object", "additionalProperties": true }
  }
}
